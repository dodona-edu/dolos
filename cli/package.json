{
  "name": "@dodona/dolos",
  "version": "2.9.3",
  "description": "Code similarity detection based on the Winnowing algorithm",
  "type": "module",
  "export": "./dist/index.js",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "dolos": "dist/cli.js"
  },
  "scripts": {
    "dolos": "npm run build && node dist/cli.js",
    "debug": "npm run build && node inspect dist/cli.js",
    "build": "tsc --build --verbose",
    "force-build": "tsc --build --verbose --force",
    "lint": "eslint src/**/*.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/dodona-edu/dolos.git"
  },
  "license": "MIT",
  "private": false,
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "typescript-eslint": "^8.63.0" ,
    "eslint": "^10.7.0",
    "@eslint/js": "^10.0.1",
    "typescript": "7.0.2"
  },
  "dependencies": {
    "@dodona/dolos-lib": "3.5.1",
    "@dodona/dolos-web": "2.9.3",
    "chalk": "^5.6.2",
    "cliui": "^9.0.1",
    "commander": "^15.0.0",
    "csv-stringify": "^6.8.1",
    "open": "^11.0.0",
    "tree-sitter": "^0.25.0"
  },
  "bugs": {
    "url": "https://github.com/dodona-edu/dolos/issues"
  },
  "homepage": "https://dolos.ugent.be",
  "keywords": [
    "plagiarism",
    "plagiarism-checker",
    "plagiarism detection",
    "similarity",
    "code similarity"
  ]
}
